{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "Python Debugger: test.py (Auto Reload)",
            "type": "debugpy",
            "request": "launch",
            "program": "test/test.py",
            "console": "integratedTerminal",
            "autoReload": {
                "enable": true
            }
        },
        {
            "name": "Python Debugger: test_dubins.py (Auto Reload)",
            "type": "debugpy",
            "request": "launch",
            "program": "test/test_dubins.py",
            "console": "integratedTerminal",
            "autoReload": {
                "enable": true
            }
        }
    ]
}